<%= slug.pascal %> = require <%- h.quote(slug.snake) %>

-- a couple of helper functions
starts_with = (str, prefix) ->
  str\sub(1, #prefix) == prefix

contains = (list, element) ->
  for item in *list
    if item == element
      return true
  false
<%
    local function format_predicate(pred)
      if pred == "fn(x) -> true"                then return "(_) -> true" end
      if pred == "fn(x) -> false"               then return "(_) -> false" end
      if pred == "fn(x) -> x % 2 == 1"          then return "(num) -> num % 2 == 1" end
      if pred == "fn(x) -> x % 2 == 0"          then return "(num) -> num % 2 == 0" end
      if pred == "fn(x) -> contains(x, 5)"      then return "(list) -> contains list, 5" end
      if pred == "fn(x) -> starts_with(x, 'z')" then return "(str) -> starts_with str, 'z'" end
      return pred
    end
    local function format_list(list)
      if h.is_empty(list) then
        return '{}'
      elseif type(list[1]) == 'string' then
        return h.word_list(list)
      else
        return h.int_list(list)
      end
    end
    local function format_value(val, level)
      if h.is_empty(val) then
        return '{}'
      elseif type(val[1]) == 'table' then -- list of lists
        local rows = {}
        for _, row in ipairs(val) do
          rows[#rows + 1] = h.indent(format_list(row), level + 1)
        end
        table.insert(rows, 1, '{')
        table.insert(rows, h.indent('}', level))
        return table.concat(rows, '\n')
      else
        return format_list(val)
      end
    end

-%>

describe <%- h.quote(slug.kebab .. ':') %>, ->
<% for i, case in ipairs(data.cases) do -%>
  <%= test_cmd(i == 1) %> <%- h.quote(case.description) %>, ->
    result = <%= slug.pascal %>.<%= case.property %> <%- format_value(case.input.list, 2) %>, <%- format_predicate(case.input.predicate) %>
    expected = <%- format_value(case.expected, 2) %>
    assert.are.same expected, result

<% end -%>
