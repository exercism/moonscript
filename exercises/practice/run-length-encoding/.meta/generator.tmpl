import encode, decode from require 'run_length_encoding'

describe 'run-length-encoding:', ->
<% for i, group in ipairs(data.cases) do -%>
  describe <%- h.quote(group.description .. ':') %>, ->
<%   for j, case in ipairs(group.cases) do -%>
    <%= test_cmd(i == 1 and j == 1) %> <%- h.quote(case.description) %>, ->
<% if case.property == 'consistency' then -%>
      encoded = encode <%- h.quote(case.input.string) %>
      decoded = decode encoded
      assert.are.equal <%- h.quote(case.expected) %>, decoded
<% else -%>
      result = <%= case.property %> <%- h.quote(case.input.string) %>
      assert.are.equal <%- h.quote(case.expected) %>, result
<% end -%>

<%   end -%>
<% end -%>
