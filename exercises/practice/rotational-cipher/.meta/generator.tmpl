RotationalCipher = require 'rotational_cipher'

describe 'rotational-cipher:', ->
<% for i, case in ipairs(data.cases) do -%>
  <%= test_cmd(i == 1) %> <%- h.quote(case.description) %>, ->
    result = RotationalCipher.rotate <%- h.quote(case.input.text) %>, <%= case.input.shiftKey %>
    expected = <%- h.quote(case.expected) %>
    assert.are.equal expected, result

<% end -%>
