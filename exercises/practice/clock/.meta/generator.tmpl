<%= slug.pascal %> = require <%- h.quote(slug.snake) %>

describe <%- h.quote(slug.kebab .. ':') %>, ->
<% for i, group in ipairs(data.cases) do -%>
  describe <%- h.quote(group.description .. ':') %>, ->
<%   for j, case in ipairs(group.cases) do -%>
    <%= test_cmd(i == 1 and j == 1) %> <%- h.quote(case.description) %>, ->
<%     if case.property == 'create' or case.property == 'add' or case.property == 'subtract' then -%>
      clock = Clock hour: <%= case.input.hour %>, minute: <%= case.input.minute %>
<%       if case.property == 'add' or case.property == 'subtract' then -%>
      clock\<%= case.property %> <%= case.input.value %>
<%       end -%>
      assert.are.equal <%- h.quote(case.expected) %>, tostring clock

<%     elseif case.property == 'equal' then -%>
      a = Clock hour: <%= case.input.clock1.hour %>, minute: <%= case.input.clock1.minute %>
      b = Clock hour: <%= case.input.clock2.hour %>, minute: <%= case.input.clock2.minute %>
      assert.is_<%= case.expected %>, a\equals(b)

<%     end -%>
<%   end -%>
<% end -%>
