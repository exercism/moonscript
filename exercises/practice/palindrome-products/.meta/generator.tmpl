<%= slug.pascal %> = require <%- h.quote(slug.snake) %>
<%
    local function value(val)
        if h.is_json_null(val) then
            return nil
        else
            return val
        end
    end
-%>

describe <%- h.quote(slug.kebab .. ':') %>, ->
<% for i, case in ipairs(data.cases) do -%>
  <%= test_cmd(i == 1) %> <%- h.quote(case.description) %>, ->
<%   if not case.expected.error then -%>
    palindrome, factors = <%= slug.pascal %>.<%= case.property %> <%= case.input.min %>, <%= case.input.max %>
    expected_palindrome = <%= value(case.expected.value) %>
    expected_factors    = <%= h.int_lists(case.expected.factors, 2) %>
    assert.are.equal expected_palindrome, palindrome
    assert.are.same  expected_factors, factors

<%   else -%>
    f = -> <%= slug.pascal %>.<%= case.property %> <%= case.input.min %>, <%= case.input.max %>
    assert.has.errors f, <%- h.quote(case.expected.error) %>

<%   end -%>
<% end -%>
